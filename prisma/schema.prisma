generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite doesn't support enums or arrays natively.
// Tags stored as JSON string in SQLite. Use Postgres for production.

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  brandColor String? @default("#2563eb")
  figmaToken String?
  smtpHost String?
  smtpPort Int?
  smtpUser String?
  smtpPass String?
  smtpFromEmail String?
  smtpFromName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  contacts  Contact[]
  segments  Segment[]
  campaigns Campaign[]
  templates Template[]
  workflows Workflow[]
}

model User {
  id             String       @id @default(cuid())
  name           String?
  email          String       @unique
  emailVerified  DateTime?
  image          String?
  role           String       @default("admin") // admin | manager
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id             String   @id @default(cuid())
  email          String?
  phone          String?
  firstName      String?
  lastName       String?
  customFields   Json?    // JSON object for custom field values
  tags           String @default("[]") // JSON array of tag strings
  source         String?  // "import" | "manual" | "api"
  isSubscribed   Boolean  @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  segmentMemberships SegmentMember[]
  campaignEvents     CampaignEvent[]
  workflowExecutions WorkflowExecution[]

  @@index([organizationId, email])
  @@index([organizationId, tags])
}

model Segment {
  id             String   @id @default(cuid())
  name           String
  description    String?
  rules          Json?    // Segment rules tree: { "logic": "and", "conditions": [...] }
  contactCount   Int      @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members          SegmentMember[]
  campaigns        Campaign[]
}

model SegmentMember {
  segmentId String
  contactId String
  segment   Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([segmentId, contactId])
  @@index([segmentId])
  @@index([contactId])
}

model Template {
  id             String   @id @default(cuid())
  name           String
  description    String?
  subject        String?  // Default subject line
  bodyHtml       String
  variables      String @default("[]") // JSON array of variable names
  previewText    String?
  category       String   @default("marketing") // marketing | transactional
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaigns Campaign[]
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  type           String   @default("email") // email | sms
  status         String   @default("draft") // draft | scheduled | sending | sent | cancelled
  scheduledAt    DateTime?
  sentAt         DateTime?
  subject        String?
  fromName       String?
  fromEmail      String?
  replyTo        String?
  trackOpens     Boolean  @default(true)
  trackClicks    Boolean  @default(true)
  totalRecipients Int     @default(0)
  sentCount      Int      @default(0)
  openCount      Int      @default(0)
  clickCount     Int      @default(0)
  bounceCount    Int      @default(0)
  unsubscribeCount Int    @default(0)
  isAbTest       Boolean  @default(false)
  subjectB       String?
  splitPercent   Int      @default(50)
  winnerMetric   String   @default("open") // open | click
  winnerId       String?  // "a" | "b"
  templateId     String?
  template       Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  segmentId      String?
  segment        Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  events CampaignEvent[]
}

model CampaignEvent {
  id         String   @id @default(cuid())
  type       String   // sent | open | click | bounce | unsubscribe | complaint
  recipientEmail String?
  metadata   Json?    // click: { url, userAgent } | bounce: { code, reason }
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([campaignId, type])
  @@index([campaignId, createdAt])
}

model Workflow {
  id             String   @id @default(cuid())
  name           String
  description    String?
  status         String   @default("draft") // draft | active | paused
  triggerType    String   @default("manual") // manual | scheduled | webhook
  triggerConfig  String?  // JSON: { cron?, webhookUrl?, segmentId? }
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  nodes    WorkflowNode[]
  edges    WorkflowEdge[]
  executions WorkflowExecution[]

  @@index([organizationId, status])
}

model WorkflowNode {
  id         String @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type       String  // trigger | sendEmail | delay | condition | updateContact | webhook | end
  label      String?
  config     String  // JSON: node configuration (templateId, duration, field, value, etc.)
  positionX  Float   @default(0)
  positionY  Float   @default(0)

  outgoingEdges WorkflowEdge[] @relation("source")
  incomingEdges WorkflowEdge[] @relation("target")

  @@index([workflowId])
}

model WorkflowEdge {
  id           String @id @default(cuid())
  workflowId   String
  workflow     Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNodeId String
  targetNodeId String
  sourceNode   WorkflowNode @relation("source", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   WorkflowNode @relation("target", fields: [targetNodeId], references: [id], onDelete: Cascade)
  label        String? // For condition branches: "yes" | "no"

  @@index([workflowId])
}

model WorkflowExecution {
  id              String   @id @default(cuid())
  workflowId      String
  workflow        Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  status          String   @default("pending") // pending | running | completed | failed
  currentNodeId   String?
  currentStep     Int      @default(0)
  totalSteps      Int      @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  logs WorkflowExecutionLog[]

  @@index([workflowId, status])
  @@index([contactId])
}

model WorkflowExecutionLog {
  id          String   @id @default(cuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId      String?
  status      String   // pending | running | completed | failed | skipped
  input       String?  // JSON: input data
  output      String?  // JSON: output data
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([executionId])
}
